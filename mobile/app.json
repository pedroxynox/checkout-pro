{
  "expo": {
    "name": "Check-out PRO",
    "owner": "pedroxynox",
    "slug": "stok-center-frente-de-caixa",
    "scheme": "checkoutpro",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "primaryColor": "#0F4C81",
    "icon": "./assets/Appicon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F4C81"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "center.stok.frentedecaixa",
      "infoPlist": {
        "NSCameraUsageDescription": "O Check-out PRO usa a câmera para ler o código de barras dos fardos de insumos e para enviar as imagens dos checklists."
      }
    },
    "android": {
      "package": "center.stok.frentedecaixa",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Appicon.png",
        "backgroundColor": "#0F4C81"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "O Check-out PRO usa a câmera para ler o código de barras dos fardos de insumos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Check-out PRO acessa suas fotos para enviar as imagens dos checklists de abertura e fechamento."
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0F4C81"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://checkout-pro-api.onrender.com",
      "eas": {
        "projectId": "40ea3b1a-6c63-4f2e-8202-ba1a6f88fb05"
      }
    }
  }
}
