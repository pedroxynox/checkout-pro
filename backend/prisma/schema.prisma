// Schema Prisma do backend - Check-out PRO (gestão inteligente de supermercado)
// Banco de dados: PostgreSQL. Modelos derivados do diagrama ER do design
// (.kiro/specs/gestao-frente-de-caixa/design.md - seção "Modelos de Dados").
//
// Notas de modelagem:
// - `RegistroOperacional` e `Ausencia` referenciam pessoas que podem ser
//   Operador ou Fiscal (pessoaId é polimórfico no domínio). Para preservar a
//   integridade onde possível, RegistroOperacional mantém relações opcionais
//   explícitas para Operador e Fiscal (refletindo o ER), além do campo
//   conceitual `pessoaId`. Ausência usa apenas `pessoaId` (operador OU fiscal).
// - `EscalaEntry.funcionarioId` é polimórfico (fiscal, operador ou gerente);
//   operadores não possuem `Usuario`, portanto é mantido como identificador
//   sem chave estrangeira rígida.
// - Horários (`entrada`/`saida`) são armazenados como String "HH:mm" para
//   alinhar com a lógica de domínio (tipo Time) de classificação de turno.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums --------------------------------------

enum Perfil {
  GERENTE
  GERENTE_DESENVOLVEDOR
  SUPERVISOR
  FISCAL
  IMPORTADOR
}

// Tipo de registro operacional / tipo de arquivo de importação.
enum TipoRegistro {
  CANCELAMENTO
  TROCO
  RECARGA
  DEVOLUCAO
}

enum CategoriaInsumo {
  SACOLA
  BOBINA
  PANO
  ALCOOL
  OUTRO
}

enum StatusLote {
  ABERTO
  ENCERRADO
}

enum StatusChecklist {
  PENDENTE
  FEITO
}

enum TipoChecklist {
  ABERTURA
  FECHAMENTO
}

enum StatusFiscal {
  DISPONIVEL
  INTERVALO
  FORA_EXPEDIENTE
}

enum StatusRequisicao {
  PENDENTE
  APROVADA
  NEGADA
}

// Estado de uma solicitação automática de advertência (por falta não
// justificada). PENDENTE = aguarda decisão do gerente; APROVADA = advertência
// carregada em Sanções; CANCELADA = descartada (ex.: falta foi justificada).
enum StatusSolicitacaoAdvertencia {
  PENDENTE
  APROVADA
  CANCELADA
}

enum TurnoFiscal {
  ABERTURA
  INTERMEDIARIO
  FECHAMENTO
}

// Tipo de incidência de escala (por data). Genérico por `tipo` para crescer
// sem novas tabelas. O primeiro evento é "não retornou do intervalo".
enum TipoIncidenciaEscala {
  NAO_RETORNO_INTERVALO
  ATRASO
  SAIDA_ANTECIPADA
  RETORNO_TARDIO
  ADVERTENCIA
  SUSPENSAO
}

// ---------------------------- Modelos -------------------------------------

model Usuario {
  id        String   @id @default(uuid())
  login     String   @unique
  nome      String?
  senhaHash String
  perfil    Perfil
  online    Boolean  @default(false)
  tokenVersion Int      @default(0)
  criadoEm  DateTime @default(now())

  fiscal       Fiscal?
  notificacoes Notificacao[]
  importacoes  RegistroImportacao[] @relation("ImportadoPor")
  movimentos   MovimentoEstoque[]   @relation("ResponsavelMovimento")

  @@map("usuarios")
}

// [DEPRECADO] Operador "simples" (só nome) do fluxo antigo de importação
// CSV/XLSX. Os operadores agora são pessoas do Cadastro Unificado de
// Colaboradores (model `Colaborador`, funcao OPERADOR). Não é mais lido nem
// escrito pelo app; mantido só para preservar dados/histórico (sem migração
// destrutiva). Ver também `RegistroOperacional` (mesmo fluxo antigo).
model Operador {
  id       String   @id @default(uuid())
  nome     String   @unique
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  registros RegistroOperacional[]

  @@map("operadores")
}

model Fiscal {
  id        String      @id @default(uuid())
  nome      String      @unique
  turno     TurnoFiscal
  especial  Boolean     @default(false)
  usuarioId String?     @unique
  criadoEm  DateTime    @default(now())

  usuario   Usuario?              @relation(fields: [usuarioId], references: [id])
  pontos    RegistroPontoFiscal[]
  registros RegistroOperacional[]

  @@map("fiscais")
}

// [DEPRECADO] Registro do fluxo ANTIGO de importação CSV/XLSX (associado a
// `Operador`/`Fiscal` por id). O fluxo atual usa `RegistroArrecadacao`
// (vinculado por identificador ao Cadastro de Colaboradores). Não é mais
// lido nem escrito; mantido para histórico (sem migração destrutiva).
model RegistroOperacional {
  id           String       @id @default(uuid())
  tipo         TipoRegistro
  data         DateTime
  pessoaId     String
  valor        Decimal      @db.Decimal(12, 2)
  importacaoId String?
  operadorId   String?
  fiscalId     String?

  importacao RegistroImportacao? @relation(fields: [importacaoId], references: [id])
  operador   Operador?           @relation(fields: [operadorId], references: [id])
  fiscal     Fiscal?             @relation(fields: [fiscalId], references: [id])

  @@index([tipo, data])
  @@map("registros_operacionais")
}

model RegistroImportacao {
  id                   String       @id @default(uuid())
  tipo                 TipoRegistro
  dataReferencia       DateTime
  importadoEm          DateTime     @default(now())
  importadoPor         String?
  nomesNaoReconhecidos Json         @default("[]")

  usuario   Usuario?              @relation("ImportadoPor", fields: [importadoPor], references: [id])
  registros RegistroOperacional[]

  @@index([dataReferencia])
  @@map("registros_importacao")
}

model VendaDiaria {
  id    String   @id @default(uuid())
  data  DateTime @unique
  valor Decimal  @db.Decimal(14, 2)

  @@map("vendas_diarias")
}

// Vendas por hora de um dia, vindas do arquivo .txt enviado diariamente.
// Guarda hora (0..23) + valor. O total do dia é a soma das horas e é
// espelhado em VendaDiaria, que alimenta os percentuais dos indicadores.
model VendaHora {
  id    String   @id @default(uuid())
  data  DateTime
  hora  Int
  valor Decimal  @db.Decimal(14, 2)

  @@unique([data, hora])
  @@index([data])
  @@map("vendas_hora")
}

// Registro de arrecadacao/lancamento por operador, vindo dos arquivos .txt que
// o fiscal sobe (troco solidario, recargas, cancelamentos, devolucoes). Guarda
// apenas o essencial: nome do operador + valor, por tipo e data (dia do
// fechamento). Alimenta os indicadores (total dia/semana/mes e ranking).
model RegistroArrecadacao {
  id            String   @id @default(uuid())
  tipo          String
  data          DateTime
  matricula     String?
  nome          String
  valor         Decimal  @db.Decimal(12, 2)
  quantidade    Int?
  autorizadoPor String?
  motivo        String?
  // Vínculo canônico (Cadastro Unificado de Colaboradores). Nullable durante a
  // transição; resolvido por identificador na importação. `nome`/`matricula`
  // brutos seguem guardados para auditoria.
  colaboradorId   String?
  autorizadoPorId String?
  criadoEm      DateTime @default(now())

  @@index([tipo, data])
  @@index([colaboradorId])
  @@map("registros_arrecadacao")
}

// Marca de que um tipo de arrecadação NÃO teve movimento num dia (ex.: nenhum
// cancelamento de itens). Permite ao Fechamento distinguir "sem movimento" de
// "pendente/não enviado". Único por (tipo, data).
model ArrecadacaoSemMovimento {
  id         String   @id @default(uuid())
  tipo       String
  data       DateTime
  marcadoPor String?
  criadoEm   DateTime @default(now())

  @@unique([tipo, data])
  @@map("arrecadacao_sem_movimento")
}

model LoteApae {
  id                String     @id @default(uuid())
  quantidadeInicial Int
  saldoAtual        Int
  quantidadeVendida Int        @default(0)
  dataInicio        DateTime   @default(now())
  dataEncerramento  DateTime?
  status            StatusLote @default(ABERTO)

  movimentos MovimentoLoteApae[]

  @@map("lotes_apae")
}

// Movimento de venda de sacolas APAE: cada atualização de saldo gera um
// registro com quantas foram vendidas desde a contagem anterior, com data.
// Permite tendência, velocidade de venda, previsão de fim de lote e
// arrecadação por período (sem exigir contagem por venda — só pelo saldo).
model MovimentoLoteApae {
  id            String   @id @default(uuid())
  loteId        String
  vendidas      Int
  saldoApos     Int
  em            DateTime @default(now())
  responsavelId String?

  lote LoteApae @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@index([em])
  @@index([loteId])
  @@map("movimentos_lote_apae")
}

// Configuração (singleton) das Sacolas APAE: preço unitário e meta mensal de
// arrecadação. Editável pelo gestor sem redeploy.
model ConfigApae {
  id            String   @id @default("apae")
  precoSacola   Float    @default(0.49)
  metaMensal    Float    @default(500)
  atualizadoEm  DateTime @default(now()) @updatedAt
  atualizadoPor String?

  @@map("config_apae")
}

// Configuração (singleton) do Painel de Vendas: meta mensal de faturamento.
// Editável pelo gestor sem redeploy. Quando metaMensal = 0, considera-se
// "sem meta definida" (a projeção é exibida sem comparação).
model ConfigVendas {
  id            String   @id @default("vendas")
  metaMensal    Float    @default(0)
  atualizadoEm  DateTime @default(now()) @updatedAt
  atualizadoPor String?

  @@map("config_vendas")
}

// Configuração (singleton) global do Sistema. Guarda a Data_Inicial_Sistema:
// data a partir da qual registros podem ser cadastrados/editados e a partir da
// qual começam os calendários do app. Editável pelo gestor sem redeploy.
model ConfigSistema {
  id            String   @id @default("sistema")
  dataInicial   DateTime @default("2026-07-01T00:00:00.000Z")
  atualizadoEm  DateTime @default(now()) @updatedAt
  atualizadoPor String?

  @@map("config_sistema")
}

model Insumo {
  id           String          @id @default(uuid())
  nome         String
  categoria    CategoriaInsumo
  saldo        Int             @default(0)
  limiteMinimo Int             @default(0)
  // Unidade base de contagem do saldo (ex.: "sacola", "bobina", "metro", "litro").
  unidade      String          @default("un")
  // Embalagem de entrada e quantas unidades base ela contém (ex.: fardo=1000
  // sacolas, caixa=20 bobinas, rolo=100 metros, galão=5 litros).
  embalagem    String          @default("un")
  fatorEmbalagem Int           @default(1)
  ativo        Boolean         @default(true)

  movimentos  MovimentoEstoque[]
  requisicoes Requisicao[]
  pedidosRecorrentes PedidoRecorrente[]
  sugestoes   SugestaoPedido[]

  @@map("insumos")
}

model Fardo {
  id               String @id @default(uuid())
  codigoBarras     String @unique
  quantidadeSacolas Int

  @@map("fardos")
}

model MovimentoEstoque {
  id            String   @id @default(uuid())
  insumoId      String
  delta         Int
  responsavelId String?
  dataHora      DateTime @default(now())
  destino       String?
  pdvId         String?
  // Origem do movimento para o "Controle de requisição" (ex.: ENTRADA,
  // REQUISICAO, COMPRA, AJUSTE, CONSUMO, FARDO). Entradas têm delta > 0.
  origem        String?
  // Nomes (snapshot, mesmo padrão de auditoria de Requisicao) para exibição:
  // - responsavelNome: quem REGISTROU o movimento (saída) ou quem APROVOU (entrada de requisição).
  // - requisitanteNome: quem SOLICITOU (apenas em entradas vindas de requisição).
  responsavelNome  String?
  requisitanteNome String?

  insumo      Insumo   @relation(fields: [insumoId], references: [id])
  responsavel Usuario? @relation("ResponsavelMovimento", fields: [responsavelId], references: [id])

  @@index([insumoId])
  @@map("movimentos_estoque")
}

// Requisição de insumo solicitada por um fiscal e decidida (aprovada/negada)
// por gerente ou supervisor. Ao aprovar, gera uma entrada no estoque.
model Requisicao {
  id              String           @id @default(uuid())
  insumoId        String
  quantidade      Int
  status          StatusRequisicao @default(PENDENTE)
  automatica      Boolean          @default(false)
  observacao      String?
  solicitanteId   String?
  solicitanteNome String?
  criadaEm        DateTime         @default(now())
  decididaPorId   String?
  decididaPorNome String?
  decididaEm      DateTime?
  motivo          String?

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([status])
  @@map("requisicoes")
}

// Solicitação automática de advertência por falta NÃO justificada (ADR 0013).
// Um cron diário (08:00) cria uma solicitação PENDENTE para cada falta que
// segue sem justificar do dia anterior ou antes, notificando o gerente. A
// advertência NÃO é lançada sem autorização: o gerente APROVA (cria a
// advertência em Sanções, `incidenciaId`) ou CANCELA (ex.: a falta foi
// justificada e ele esqueceu de marcar no app). `ausenciaId` é único para
// garantir uma única solicitação por falta (idempotência do cron).
model SolicitacaoAdvertencia {
  id              String                       @id @default(uuid())
  colaboradorId   String
  ausenciaId      String                       @unique
  dataFalta       DateTime
  motivo          String                       @default("Desídia (falta injustificada)")
  status          StatusSolicitacaoAdvertencia @default(PENDENTE)
  criadaEm        DateTime                     @default(now())
  decididaPorId   String?
  decididaPorNome String?
  decididaEm      DateTime?
  // Advertência (IncidenciaEscala) criada quando aprovada.
  incidenciaId    String?
  // Motivo/observação da decisão (ex.: "Falta justificada").
  motivoDecisao   String?

  @@index([status])
  @@index([colaboradorId])
  @@map("solicitacoes_advertencia")
}

/// Marca idempotente de que o fechamento de um dia foi concluído (e notificado).
/// A unicidade de `data` garante notificação exatamente uma vez, mesmo sob
/// uploads concorrentes.
model FechamentoConcluido {
  id          String   @id @default(uuid())
  data        DateTime @unique
  concluidoEm DateTime @default(now())

  @@map("fechamentos_concluidos")
}

// Registro de Ponto (leitor de papelito): tipo de cada batida do dia, na ordem
// 1=entrada, 2=saída p/ intervalo, 3=retorno, 4=encerramento; extras a partir
// da 5ª.
enum TipoBatida {
  ENTRADA
  SAIDA_INTERVALO
  RETORNO_INTERVALO
  ENCERRAMENTO
  EXTRA
}

// Origem da batida: MANUAL (digitada/confirmada), LEITOR (OCR do papelito) ou
// EDITADO (corrigida depois).
enum OrigemBatida {
  MANUAL
  LEITOR
  EDITADO
}

// Tipo da pessoa dona da batida (padrão polimórfico, para estender a operadores).
enum TipoPessoaPonto {
  FISCAL
  OPERADOR
}

// Uma batida de ponto lida do relógio físico (papelito). Uma linha por batida;
// o tipo é derivado da ordem cronológica no dia. A hora que vale é a do
// papelito (`hora`), não a de carregamento (`criadoEm`).
model BatidaPonto {
  id                String          @id @default(uuid())
  pessoaId          String
  tipoPessoa        TipoPessoaPonto @default(FISCAL)
  colaboradorId     String?
  data              DateTime
  hora              DateTime
  tipo              TipoBatida
  origem            OrigemBatida    @default(MANUAL)
  confianca         Float?
  comprovanteUrl    String?
  registradoPor     String
  registradoPorNome String?
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt

  @@index([pessoaId, data])
  @@index([colaboradorId])
  @@map("batidas_ponto")
}

// Registro de ponto/jornada dos fiscais: cada transição de status (entrar =
// DISPONIVEL, sair para INTERVALO, voltar = DISPONIVEL, encerrar =
// FORA_EXPEDIENTE). O status atual de um fiscal é o do último registro do dia;
// somando as durações por status calcula-se a jornada (tempo trabalhando,
// tempo de intervalo e carga horária do dia).
model RegistroPontoFiscal {
  id       String       @id @default(uuid())
  fiscalId String
  colaboradorId String?
  status   StatusFiscal
  data     DateTime
  em       DateTime     @default(now())

  fiscal Fiscal @relation(fields: [fiscalId], references: [id])

  @@index([fiscalId, data])
  @@index([colaboradorId])
  @@map("registros_ponto_fiscal")
}

model EscalaEntry {
  id            String  @id @default(uuid())
  funcionarioId String
  colaboradorId String?
  diaSemana     Int
  entrada       String?
  saida         String?
  intervaloMin  Int     @default(0)
  folga         Boolean @default(false)
  especial      Boolean @default(false)

  @@index([funcionarioId, diaSemana])
  @@index([colaboradorId])
  @@map("escala_entries")
}

// [DEPRECADO] Turno fixo de um operador (Quadro de Operadores antigo).
// A escala dos operadores agora é derivada do Cadastro Unificado de
// Colaboradores (model `Colaborador`, funcao OPERADOR), que guarda os mesmos
// campos de horário/folga. Esta tabela não é mais lida nem escrita pelo app;
// fica apenas para preservar dados/histórico e evitar uma migração destrutiva.
// As faltas pontuais ficam em `Ausencia` (pessoaId = id do Colaborador).
model OperadorTurno {
  id             String   @id @default(uuid())
  nome           String   @unique
  // Gênero ('M' ou 'F') para o avatar representativo.
  genero         String?
  // Horário Seg–Qui ("HH:mm").
  entradaSemana  String
  saidaSemana    String
  // Horário Sex–Sáb ("HH:mm"); a loja abre ~1h a mais.
  entradaFds     String
  saidaFds       String
  // Dia de folga fixo: 0=Dom, 1=Seg, ..., 6=Sáb.
  folgaDiaSemana Int
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())

  @@map("operador_turnos")
}

model Checklist {
  id         String          @id @default(uuid())
  tipo       TipoChecklist
  data       DateTime
  status     StatusChecklist @default(PENDENTE)
  imagemUrl  String?
  enviadoPor String?
  enviadoEm  DateTime?
  // Verdadeiro se a imagem foi enviada dentro da janela (pontual).
  noPrazo    Boolean?
  // Hash (sha256) da imagem enviada, para detectar foto repetida (anti-fraude).
  imagemHash String?

  @@unique([tipo, data])
  @@map("checklists")
}

// Estado de justificativa de uma ocorrência (falta ou não-retorno de intervalo).
// PENDENTE = ainda não analisada; JUSTIFICADA = abonada (com motivo); 
// INJUSTIFICADA = analisada e confirmada como falta real.
enum StatusJustificativa {
  PENDENTE
  JUSTIFICADA
  INJUSTIFICADA
}

// Motivo da justificativa. Define, de forma determinista, o quanto a ocorrência
// ainda pesa no score (ver ADR 0009): ATESTADO_MEDICO pesa muito pouco; os
// demais motivos justificados pesam pouco; PENDENTE/INJUSTIFICADA pesam integral.
enum MotivoJustificativa {
  ATESTADO_MEDICO
  ABONADA
  LICENCA
  ATRASO_JUSTIFICADO
  OUTRO
}

model Ausencia {
  id       String   @id @default(uuid())
  pessoaId String
  colaboradorId String?
  data     DateTime

  // Quem registrou a falta (auditoria — 10 pessoas lançam faltas no app).
  registradaPorId   String?
  registradaPorNome String?

  // Justificativa (abono) da falta, aplicada DEPOIS do registro. O estado é
  // persistido; o peso no score é derivado do motivo (função pura). Auditoria
  // de quem justificou e quando.
  statusJustificativa     StatusJustificativa  @default(PENDENTE)
  motivoJustificativa     MotivoJustificativa?
  observacaoJustificativa String?
  justificadaPorId        String?
  justificadaPorNome      String?
  justificadaEm           DateTime?

  @@unique([pessoaId, data])
  @@index([colaboradorId])
  @@index([statusJustificativa])
  @@map("ausencias")
}

model Notificacao {
  id        String   @id @default(uuid())
  usuarioId String
  titulo    String
  mensagem  String
  canalPush Boolean  @default(false)
  canalInApp Boolean @default(false)
  lida      Boolean  @default(false)
  criadaEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("notificacoes")
}

// Token de push (Expo) de um dispositivo, vinculado ao usuário que o registrou.
// Um usuário pode ter vários dispositivos; um token pertence a um usuário (o
// último que fez login nele). Usado para enviar push (Expo Push Service) além
// da entrega in-app/WebSocket. `usuarioId` é um id "solto" (sem FK rígida),
// seguindo o padrão do schema (ADR 0005).
model PushToken {
  id           String   @id @default(uuid())
  token        String   @unique
  usuarioId    String
  plataforma   String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  @@index([usuarioId])
  @@map("push_tokens")
}

// Mensagem de uma conversa com o assistente de IA (chat flutuante). Cada
// usuário tem o seu próprio fio (isolado por `usuarioId`). As conversas são
// efêmeras: ficam guardadas por 24h (para o usuário recuperar a conversa caso
// feche o app sem querer) e são apagadas por um cron diário. `papel` segue a
// convenção da API Gemini: 'user' (pergunta) ou 'model' (resposta).
model MensagemAssistente {
  id        String   @id @default(uuid())
  usuarioId String
  papel     String
  conteudo  String
  criadaEm  DateTime @default(now())

  @@index([usuarioId, criadaEm])
  @@map("mensagens_assistente")
}

// Pedido recorrente de insumos: padrão configurável (semanal/quinzenal) com
// quantidades habituais. O cron gera sugestões automaticamente e o gestor
// confirma ou ajusta antes de virar requisição/entrada.
model PedidoRecorrente {
  id            String   @id @default(uuid())
  insumoId      String
  quantidade    Int
  /// Frequência em dias (7 = semanal, 15 = quinzenal).
  frequenciaDias Int     @default(7)
  /// Dia da semana preferencial para sugestão (1=Seg..6=Sáb, 0=Dom).
  diaSugestao   Int      @default(1)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@map("pedidos_recorrentes")
}

// Sugestão de pedido gerada pelo sistema (cron). Fica PENDENTE até o gestor
// confirmar (vira entrada) ou ignorar.
model SugestaoPedido {
  id            String   @id @default(uuid())
  insumoId      String
  quantidade    Int
  /// Quantidade ajustada pelo gestor (se diferente da sugestão).
  quantidadeAjustada Int?
  status        StatusSugestao @default(PENDENTE)
  /// Lote: agrupa sugestões geradas juntas (ex.: "pedido semanal 2026-06-23").
  lote          String?
  criadaEm      DateTime @default(now())
  confirmadaEm  DateTime?
  confirmadaPor String?

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([status])
  @@map("sugestoes_pedido")
}

enum StatusSugestao {
  PENDENTE
  CONFIRMADA
  IGNORADA
}


// Meta configurável de um indicador de arrecadação. Substitui as metas
// hardcoded (CONFIG_ARRECADACAO) como fonte única de verdade — o gestor pode
// editar via app sem redeploy. Quando não existe registro, usa-se o default.
model MetaIndicador {
  id            String   @id @default(uuid())
  /// Tipo do indicador (ex.: TROCO_SOLIDARIO, CANCELAMENTO_ITENS).
  tipo          String   @unique
  /// Valor da meta: R$ (base FIXA) ou % sobre vendas (base VENDAS).
  meta          Float
  /// Limite do amarelo (opcional); se ausente, derivado automaticamente.
  limiteAmarelo Float?
  atualizadoEm  DateTime @default(now()) @updatedAt
  atualizadoPor String?

  @@map("metas_indicador")
}

// Meta MENSAL de um indicador (definida pelo gestor no Centro de Controle ▸
// Metas). Diferente de MetaIndicador (valor único global), aqui a meta é por
// período mensal (`anoMes` = "AAAA-MM"), permitindo metas diferentes a cada
// mês. Tipos: VENDAS (R$), RECARGAS_CELULAR (R$), CANCELAMENTO_ITENS (%),
// CANCELAMENTO_CUPOM (%), DEVOLUCOES (%). Quando não há registro para o mês,
// usa-se o valor padrão de CONFIG_METAS (e, para VENDAS, a config legada).
model MetaMensal {
  id            String   @id @default(uuid())
  /// Tipo da meta (ex.: VENDAS, CANCELAMENTO_ITENS).
  tipo          String
  /// Período mensal no formato "AAAA-MM" (ex.: "2026-06").
  anoMes        String
  /// Valor da meta: R$ (vendas/recargas) ou % sobre vendas (cancelamentos/devoluções).
  meta          Float
  atualizadoEm  DateTime @default(now()) @updatedAt
  atualizadoPor String?

  @@unique([tipo, anoMes])
  @@map("metas_mensais")
}


// --------------------- Cadastro Unificado de Colaboradores -----------------
// Pessoa canônica da operação (operador/fiscal/gestor). A `matricula` é o
// registro único; os identificadores mapeiam os códigos dos arquivos (login e
// matrícula) para o mesmo colaborador, permitindo resolver os movimentos sem
// depender de comparar nomes. Construído de forma aditiva: durante a transição
// convive com Operador/OperadorTurno/Fiscal (que seguem alimentando as telas).

enum FuncaoColaborador {
  OPERADOR
  FISCAL
  SUPERVISOR
  GESTOR
}

enum TurnoColaborador {
  ABERTURA
  INTERMEDIARIO
  FECHAMENTO
  APOIO
}

enum TipoIdentificador {
  MATRICULA
  LOGIN
}

model Colaborador {
  id        String            @id @default(uuid())
  matricula String            @unique
  nome      String
  funcao    FuncaoColaborador
  genero    String?
  ativo     Boolean           @default(true)

  // Data do desligamento (quando `ativo` passou a false). Base da JANELA DE
  // RETENÇÃO: a purga mensal de inativos só apaga a ficha e o histórico de RRHH
  // depois de decorridos RETENCAO_INATIVOS_MESES meses desde esta data — assim o
  // histórico disciplinar/trabalhista de um desligado recente é preservado
  // (proteção legal). Null enquanto o colaborador estiver ativo.
  desligadoEm DateTime?

  // Data de admissão (entrada na casa). Base ÚNICA e determinista do módulo de
  // Contratos (tempo de casa + marcos de 45/90 dias). Opcional/aditivo: fichas
  // antigas ficam sem data até o gestor preenchê-la. Pode ser anterior à
  // Data_Inicial_Sistema (admissões históricas são legítimas — ver ADR 0008).
  dataAdmissao DateTime?

  // Escala (apenas operadores normalmente). Opcional para não obrigar fiscais.
  turno          TurnoColaborador?
  entradaSemana  String?
  saidaSemana    String?
  entradaFds     String?
  saidaFds       String?
  folgaDiaSemana Int?

  // Login do app (apenas fiscais/gestores). Escalar (sem relação rígida),
  // seguindo o padrão de IDs do schema.
  usuarioId String? @unique

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  identificadores ColaboradorIdentificador[]

  @@map("colaboradores")
}

model ColaboradorIdentificador {
  id            String            @id @default(uuid())
  colaboradorId String
  tipo          TipoIdentificador
  // Valor normalizado (login minúsculo / matrícula sem espaços).
  valor         String

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@unique([tipo, valor])
  @@index([colaboradorId])
  @@map("colaborador_identificadores")
}


// --------------------------- Contratos de experiência ----------------------
// Contrato de experiência brasileiro (máx. 90 dias, partido em 45 + 45). O
// ESTADO (experiência/efetivado/encerrado) é DERIVADO de `dataAdmissao`
// (Colaborador) + as DECISÕES persistidas abaixo — nunca gravado. As decisões
// são dados novos que não se derivam de uma data (ver ADR 0008). Segue o padrão
// de IDs polimórficos sem FK rígida (ADR 0005): `colaboradorId` é a ficha.

/// Marco (hito) do contrato de experiência: fim da 1ª fase (45 dias) e fim da
/// 2ª fase (90 dias). Genérico o suficiente para o ciclo 45 + 45.
enum MarcoContrato {
  MARCO_45
  MARCO_90
}

/// Resultado de uma decisão de contrato num marco.
enum ResultadoDecisaoContrato {
  APROVADO
  REPROVADO
}

/// Decisão de contrato (aprovar/reprovar) num marco (45/90 dias), com auditoria
/// (quem e quando). No máximo uma decisão por (colaborador, marco) — regravar
/// atualiza a mesma linha (upsert). O estado do contrato é derivado destas
/// decisões + `dataAdmissao`; nada de estado redundante persistido.
model DecisaoContrato {
  id              String                   @id @default(uuid())
  colaboradorId   String
  marco           MarcoContrato
  resultado       ResultadoDecisaoContrato
  decididoPorId   String?
  decididoPorNome String?
  observacao      String?
  criadoEm        DateTime                 @default(now())
  atualizadoEm    DateTime                 @default(now()) @updatedAt

  @@unique([colaboradorId, marco])
  @@index([colaboradorId])
  @@map("decisoes_contrato")
}


/// Incidência de escala por DATA (diferente de EscalaEntry, que é a plantilla
/// semanal). Genérica por `tipo` para crescer sem novas tabelas. O horário
/// ESPERADO é derivado da escala (intervaloMin); para fiscais, o horário REAL
/// pode ser detectado do ponto (RegistroPontoFiscal).
model IncidenciaEscala {
  id                 String               @id @default(uuid())
  colaboradorId      String
  funcionarioId      String?
  tipo               TipoIncidenciaEscala
  data               DateTime
  horaSaida          String?
  horaEsperadaRetorno String?
  horaReal           String?
  origem             String               @default("MANUAL") // MANUAL | DETECTADO_PONTO
  motivo             String?
  observacao         String?
  registradoPorId    String?
  registradoPorNome  String?
  // Sanções disciplinares (ADR 0012). Para SUSPENSAO: duração em dias e a data
  // final (inclusiva) para saber quem está suspenso "hoje". Vínculo opcional da
  // sanção à ocorrência que a motivou (causaTipo = FALTA ou um tipo de
  // incidência; causaData = a data dessa ocorrência) — informativo.
  diasSuspensao      Int?
  dataFim            DateTime?
  causaTipo          String?
  causaData          DateTime?
  // Justificativa (abono) do não-retorno, aplicada DEPOIS do registro — mesmo
  // modelo das faltas (Ausencia). Estado persistido; peso no score derivado do
  // motivo (ver ADR 0009). `motivo`/`observacao` acima são do registro; estes
  // são específicos da justificativa.
  statusJustificativa     StatusJustificativa  @default(PENDENTE)
  motivoJustificativa     MotivoJustificativa?
  observacaoJustificativa String?
  justificadaPorId        String?
  justificadaPorNome      String?
  justificadaEm           DateTime?
  criadoEm           DateTime             @default(now())
  atualizadoEm       DateTime             @default(now()) @updatedAt

  @@unique([colaboradorId, tipo, data])
  @@index([colaboradorId, data])
  @@index([tipo, data])
  @@index([tipo, dataFim])
  @@index([data])
  @@index([statusJustificativa])
  @@map("incidencias_escala")
}
