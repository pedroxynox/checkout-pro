# Configuração de ambiente do backend - Gestão de Frente de Caixa (Stok Center)
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.

# Porta HTTP da API
PORT=3000

# Ambiente de execução: development | test | production
NODE_ENV=development

# Conexão com o PostgreSQL (usada pelo Prisma nas próximas tarefas)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stok_center?schema=public

# Horário de fim do dia para alertas de importações pendentes (HH:mm)
HORARIO_FIM_DO_DIA=18:00
