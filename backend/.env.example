# Configuração de ambiente do backend - Check-out PRO
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.

# Porta HTTP da API
PORT=3000

# Ambiente de execução: development | test | production
NODE_ENV=development

# Conexão com o PostgreSQL (usada pelo Prisma).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/checkout_pro?schema=public

# Horário de fim do dia para alertas de importações pendentes (HH:mm)
HORARIO_FIM_DO_DIA=22:50

# Segredo de assinatura dos tokens JWT (autenticação).
# OBRIGATÓRIO em produção. Use um valor longo e aleatório (ex.: `openssl rand -hex 32`).
# Sem ele, a API recorre a um segredo padrão INSEGURO.
JWT_SECRET=
# Expiração do token de acesso (ex.: 8h, 30m, 30d). Padrão: 30d (1 mês)
JWT_EXPIRES_IN=30d


# Assistente de IA (chat flutuante) — Google Gemini.
# Chave gratuita obtida em https://aistudio.google.com/apikey
# Sem ela, o assistente responde "não configurado".
GEMINI_API_KEY=
# Modelo Gemini (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
